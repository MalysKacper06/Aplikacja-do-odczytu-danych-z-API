<Window x:Class="FridgeData.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FridgeData"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Title="Odczyt" Height="450" Width="800">
    <Canvas Background="#191818">
        <Rectangle Width="400" Height="434" HorizontalAlignment="Center" VerticalAlignment="Top" Fill="white"></Rectangle>
        <TextBlock FontSize="17" Text="PANLE STEROWANIA:"></TextBlock>
        <TextBlock Name="t1" Canvas.Left="50px" Canvas.Top="50px" Background="#373736" Foreground="white" Width="80" TextAlignment="Center">IsRunning</TextBlock>
        <TextBlock Name="t2" Canvas.Left="150px" Canvas.Top="50px" Background="#373736" Foreground="white" Width="80" TextAlignment="Center">Temperatura</TextBlock>
        <TextBlock Name="t3" Canvas.Left="250px" Canvas.Top="50px" Background="#373736" Foreground="white" Width="120" TextAlignment="Center">Error</TextBlock>

        <TextBlock Canvas.Left="400" FontSize="17" Foreground="white" Text="DANE:"></TextBlock>
        <TextBlock Canvas.Right="125px" Text="ip" Background="White"></TextBlock>
        <TextBox Name="ip_block" Width="100" Canvas.Right="20px" Text="192.168.31.250"></TextBox>
        
        <TextBlock Canvas.Right="255px" Text="port" Background="White"></TextBlock>
        <TextBox Name="port_block" Width="100" Canvas.Right="150px" Text="56000"></TextBox>

        <DataGrid Name="dtGrid" Canvas.Right="5px" Canvas.Bottom="5px" Width="350px" Height="350"></DataGrid>

        <Button Content="odczyt" Canvas.Left="140px" Canvas.Top="100px" Click="Button_Click" Background="#373736" Foreground="white"></Button>
        <Button Content="zaspis" Canvas.Left="205px" Canvas.Top="100px" Click="Button_Click_1" Background="#373736" Foreground="white"></Button>
        <Button Content="eksport" Canvas.Left="255px" Canvas.Top="100px" Click="ExportToExcel_Click" Background="#373736" Foreground="white"></Button>
        <Button Content="wykres" Canvas.Left="55px" Canvas.Top="100px" Click="Button_Click_2"  Background="#373736" Foreground="white"></Button>
        
        

           
                <RadioButton IsChecked="True" Canvas.Left="300" Click="klik1">Urzadzenie 1</RadioButton>




                <RadioButton IsChecked="False" Canvas.Left="300" Canvas.Top="15" Checked="klik2">Urzadzenie 2</RadioButton>
        <TextBlock Text="Wykres z ostatnich 10 odczytów" Canvas.Top="280"></TextBlock>

        <Rectangle Width="30" Height="100" Fill="Aqua" Canvas.Bottom="5" Canvas.Left="5" Name="r1">
            
